# Just controls how often DAGMan polls the node logs; smaller reacts faster and
# has no bearing on what this test checks. (Default is 5.)
DAGMAN_USER_LOG_SCAN_INTERVAL = 1

# Pace node submission so DAGMan gets condor_rm'ed in the middle of submitting
# the Z jobs.  NodeF sleeps 20s before the rm, so with a 5s delay roughly 4 of
# the 10 Z jobs are submitted when the rm lands -- still solidly mid-submission.
DAGMAN_SUBMIT_DELAY = 5
DAGMAN_MAX_SUBMITS_PER_INTERVAL = 10

#DAGMAN_REMOVE_NODE_JOBS = true
