use CondorTest;
use Check::SimpleJob;
use CondorUtils;
use strict;
use warnings;

my $testname = "cmd_q_shows-xml";
my $debuglevel = 2;
my $worked = 0;

my $ClusterId = 0;

my $GetClusterId = sub {
	my $cid = shift;
	$ClusterId = $cid;
	print "Resquestd Cluster Got $ClusterId\n";
	##########################
	#
	# Convoluted: This function is paased to RunCheck which uses it in RunTest in the fourth
	# position which is always an undefined variable EXCEPT when it is a call back routine 
	# to pass out the cluster Id.
	#
	##########################
	#runcmd("condor_q",{emit_output => 1});
};


my @adarray;

my $submit = sub {
	my $cmd = "condor_q -xml ";

	print "ok\n";

	# Poll until condor_q -xml returns XML content for the job
	my $valid = 0;
	for my $attempt (1..10) {
		$worked = 0;
		print "Get XML output via $cmd (attempt $attempt) - ";
		my $cmdstatus = CondorTest::runCondorTool($cmd,\@adarray,2);
		if(!$cmdstatus) {
			print "bad\n";
			CondorTest::debug("Test failure due to Condor Tool Failure<$cmd>\n",$debuglevel);
			exit(1);
		}
		print "ok\n";

		print "Check for valid XML output - ";
		my $bad_line = 0;
		foreach my $line (@adarray) {
			chomp($line);
			if($line =~ /^\s*$/) {
				# blank line
			} elsif($line =~ /^\s*<.*$/) {
				CondorTest::debug("XML<<	$line	>>\n",$debuglevel);
				$worked += 1;
			} elsif($line =~ /^.*Submitter:.*$/) {
				# submit line
			} else {
				CondorTest::debug("Lines must be blank or start with <\n",$debuglevel);
				CondorTest::debug("<<<$line>>>\n",$debuglevel);
				$bad_line = 1;
				last;
			}
		}

		if($bad_line) {
			print "bad - invalid line in XML output\n";
			CondorTest::runCondorTool("condor_rm $ClusterId",\@adarray,8,{expect_result => ANY,emit_output=>0});
			exit(1);
		}

		if($worked > 0) {
			$valid = 1;
			print "ok\n";
			last;
		}

		print "no XML content yet, retrying...\n";
		sleep(1);
	}

	CondorTest::runCondorTool("condor_rm $ClusterId",\@adarray,8,{expect_result => ANY,emit_output=>0});

	if(!$valid) {
		print "bad - never got XML output\n";
		exit(1);
	}
};

my $aborted = sub {
};

my $ExitSuccess = sub {
};

my $timed = sub
{
    die "Job should have ended by now. condor_q -xml broken!\n";
};

print "Start a long runniing job - ";

my $runresult = SimpleJob::RunCheck(
	duration => 3600,
	on_abort => $aborted,
	on_submit => $submit,
	on_success => $ExitSuccess,
	GetClusterId => $GetClusterId,
);


